# Google/Magic account signer and public Polymarket profile wallet.
WALLET_PRIVATE_KEY=0x
ACCOUNT_ADDRESS=0x

# Optional for one-time approvals, redemption, and gasless wallet operations.
POLYMARKET_RELAYER_API_KEY=
POLYMARKET_RELAYER_API_KEY_ADDRESS=

# Required only while deliberately running the live-test command.
POLYTRACKER_LIVE_ENABLED=false
POLYTRACKER_MAX_LIVE_SPEND=5
